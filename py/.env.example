# Alpaca API credentials (REQUIRED)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Trading mode
ALPACA_PAPER=true
ALLOW_LIVE_TRADING=false

# Safety gates
KILL_SWITCH=false
CIRCUIT_BREAKER_RESET=false
DRY_RUN=false

# Logging
LOG_LEVEL=INFO

# Paths (relative to each project directory: py/ or cs/)
# For Python: py/data/trades.db, py/config/trading.yaml
# For C#: Uses appsettings.json configuration
DATABASE_PATH=data/trades.db
CONFIG_PATH=config/trading.yaml
