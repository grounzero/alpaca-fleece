@namespace AlpacaFleece.AdminUI.Components.DataGrid
@using MudBlazor

<MudDrawer @bind-Open="@DrawerOpen" Anchor="Anchor.Right" Width="300px" Elevation="1">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6">Columns</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@OnCloseInternal" />
    </MudDrawerHeader>

    <MudDivider />

    <MudList T="object" Style="padding: 0;">
        @foreach (var column in Columns.Cast<dynamic>())
        {
            <MudListItem T="object" Icon="@Icons.Material.Filled.DragIndicator" InitiallyExpanded="false">
                <MudCheckBox T="bool"
                    Checked="@(!column.Hidden)" 
                    CheckedChanged="@((bool isChecked) => ToggleColumnVisibility(column, isChecked))"
                    Label="@column.Title" 
                    Dense="true" />
            </MudListItem>
        }
    </MudList>

    <MudDivider Class="my-4" />

    <MudStack Spacing="2">
        <MudButton Variant="Variant.Outlined" FullWidth="true" OnClick="@OnCloseInternal">Done</MudButton>
    </MudStack>
</MudDrawer>

@code {
    [Parameter]
    public IReadOnlyList<object> Columns { get; set; } = new List<object>();

    [Parameter]
    public EventCallback OnClose { get; set; }

    private bool DrawerOpen = true;

    private void ToggleColumnVisibility(dynamic column, bool isChecked)
    {
        column.Hidden = !isChecked;
        StateHasChanged();
    }

    private async Task OnCloseInternal()
    {
        DrawerOpen = false;
        await OnClose.InvokeAsync();
    }
}
