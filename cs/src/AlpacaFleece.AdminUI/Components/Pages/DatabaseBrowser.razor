@page "/database"
@attribute [Authorize]
@using AlpacaFleece.AdminUI.Services.DataGrid
@using AlpacaFleece.AdminUI.Components.DataGrid
@using Microsoft.AspNetCore.Components.Rendering
@inject AdminDbService DbService
@inject AdminGridDataService GridDataService
@inject ISnackbar Snackbar

<PageTitle>Database — AlpacaFleece Admin</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">Database</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Browse all database tables with advanced filtering, sorting, and searching (read-only).
</MudText>

<MudGrid Spacing="3">
    @* ── Table list panel ── *@
    <MudItem xs="12" md="3">
        <MudPaper Elevation="2" Class="pa-2">
            <MudText Typo="Typo.subtitle2" Class="pa-2">Tables</MudText>
            @if (_tableLoading)
            {
                <MudProgressLinear Indeterminate />
            }
            else
            {
                <MudList T="TableInfo" Dense SelectedValue="_selected" SelectedValueChanged="@SelectTable">
                    @foreach (var t in _tables)
                    {
                        <MudListItem T="TableInfo" Value="t">
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.body2">@t.DisplayName</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                    @t.RowCount
                                </MudChip>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>
    </MudItem>

    @* ── Data Grid Panel ── *@
    <MudItem xs="12" md="9">
        @if (_selected is null)
        {
            <MudAlert Severity="Severity.Info">Select a table on the left to browse its data.</MudAlert>
        }
        else if (_dataGridColumns == null || _dataGridColumns.Count == 0)
        {
            <MudAlert Severity="Severity.Warning">No columns found for this table.</MudAlert>
        }
        else
        {
            @* DbTableGrid - dynamic table viewer *@
            @(RenderDbTableGrid())
        }
    </MudItem>
</MudGrid>

@code {
    private List<TableInfo> _tables = [];
    private TableInfo? _selected;
    private bool _tableLoading = true;
    
    private IReadOnlyList<DbColumnDef<object>>? _dataGridColumns;

    protected override async Task OnInitializedAsync()
    {
        try 
        { 
            _tables = (await DbService.GetTableInfoAsync()).ToList(); 
        }
        catch (Exception ex) 
        { 
            Snackbar.Add($"Failed to load table list: {ex.Message}", Severity.Error); 
        }
        finally 
        { 
            _tableLoading = false; 
        }
    }

    private async Task SelectTable(TableInfo? t)
    {
        _selected = t;
        
        // Load column definitions for the selected table
        if (t != null)
        {
            try
            {
                _dataGridColumns = await GridDataService.GetColumnsAsync(t.Name);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to load columns: {ex.Message}", Severity.Error);
                _dataGridColumns = new List<DbColumnDef<object>>();
            }
        }
    }

    /// <summary>
    /// Callback for DbTableGrid to load data asynchronously.
    /// </summary>
    private async Task<GridResult<object>> LoadGridDataAsync(GridQuery query)
    {
        if (_selected == null)
        {
            return new GridResult<object>(new List<object>(), 0);
        }

        try
        {
            var result = await GridDataService.QueryAsync(_selected.Name, query);
            return result;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
            return new GridResult<object>(new List<object>(), 0);
        }
    }

    private RenderFragment RenderDbTableGrid() => builder =>
    {
        builder.OpenComponent<DbTableGrid<object>>(0);
        builder.AddAttribute(1, "TableKey", $"database_{_selected!.Name}");
        builder.AddAttribute(2, "Title", _selected!.DisplayName);
        builder.AddAttribute(3, "Columns", _dataGridColumns);
        builder.AddAttribute(4, "LoadDataAsync", (Func<GridQuery, Task<GridResult<object>>>)LoadGridDataAsync);
        builder.AddAttribute(5, "ReadOnly", true);
        builder.CloseComponent();
    };
}
