@page "/database"
@attribute [Authorize]
@inject AdminDbService DbService
@inject ISnackbar Snackbar

<PageTitle>Database — AlpacaFleece Admin</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">Database</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Browse all database tables (read-only).
</MudText>

<MudGrid Spacing="3">
    @* ── Table list panel ── *@
    <MudItem xs="12" md="3">
        <MudPaper Elevation="2" Class="pa-2">
            <MudText Typo="Typo.subtitle2" Class="pa-2">Tables</MudText>
            @if (_tableLoading)
            {
                <MudProgressLinear Indeterminate />
            }
            else
            {
                <MudList T="TableInfo" Dense SelectedValue="_selected" SelectedValueChanged="@SelectTable">
                    @foreach (var t in _tables)
                    {
                        <MudListItem T="TableInfo" Value="t">
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.body2">@t.DisplayName</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                    @t.RowCount
                                </MudChip>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>
    </MudItem>

    @* ── Data panel ── *@
    <MudItem xs="12" md="9">
        @if (_selected is null)
        {
            <MudAlert Severity="Severity.Info">Select a table on the left to browse its data.</MudAlert>
        }
        else
        {
            <MudPaper Elevation="2" Class="pa-3">
                <div class="d-flex align-center justify-space-between mb-2">
                    <MudText Typo="Typo.subtitle1">@_selected.DisplayName</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Size="Size.Small"
                                   OnClick="@ReloadData"
                                   Disabled="_dataLoading" />
                </div>

                @if (_dataLoading)
                {
                    <MudProgressLinear Indeterminate Color="Color.Primary" />
                }
                else if (_dataError is not null)
                {
                    <MudAlert Severity="Severity.Error">@_dataError</MudAlert>
                }
                else if (_rows.Count == 0)
                {
                    <MudText Class="mud-text-secondary">No rows in this table.</MudText>
                }
                else
                {
                    @* Dynamic column headers *@
                    <div style="overflow-x:auto">
                        <MudTable T="object"
                                  Items="_rows"
                                  Dense="true"
                                  Hover="true"
                                  Striped="true"
                                  FixedHeader
                                  Height="450px">
                            <HeaderContent>
                                @foreach (var col in _columns)
                                {
                                    <MudTh>@col</MudTh>
                                }
                            </HeaderContent>
                            <RowTemplate>
                                @foreach (var col in _columns)
                                {
                                    <MudTd>
                                        <MudText Typo="Typo.caption">
                                            @FormatValue(GetPropValue(context, col))
                                        </MudText>
                                    </MudTd>
                                }
                            </RowTemplate>
                        </MudTable>
                    </div>

                    @* Paging controls *@
                    <div class="d-flex align-center justify-space-between mt-2">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            Showing @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, _totalRows)) of @_totalRows rows
                        </MudText>
                        <div>
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                           Size="Size.Small"
                                           Disabled="@(_page <= 1)"
                                           OnClick="@PrevPage" />
                            <MudText Typo="Typo.caption" Style="display:inline">Page @_page</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                           Size="Size.Small"
                                           Disabled="@(_page * PageSize >= _totalRows)"
                                           OnClick="@NextPage" />
                        </div>
                    </div>
                }
            </MudPaper>
        }
    </MudItem>
</MudGrid>

@code {
    private const int PageSize = 25;

    private List<TableInfo> _tables = [];
    private TableInfo? _selected;
    private bool _tableLoading = true;
    private bool _dataLoading;
    private string? _dataError;

    private List<object> _rows = [];
    private IReadOnlyList<string> _columns = [];
    private int _totalRows;
    private int _page = 1;

    protected override async Task OnInitializedAsync()
    {
        try { _tables = (await DbService.GetTableInfoAsync()).ToList(); }
        catch (Exception ex) { Snackbar.Add($"Failed to load table list: {ex.Message}", Severity.Error); }
        finally { _tableLoading = false; }
    }

    private async Task SelectTable(TableInfo? t)
    {
        _selected = t;
        _page = 1;
        await ReloadData();
    }

    private async Task ReloadData()
    {
        if (_selected is null) return;
        _dataLoading = true;
        _dataError = null;
        _rows = [];
        try
        {
            var (rows, total, columns) =
                await DbService.GetTableDataAsync(_selected.Name, _page, PageSize);
            _rows = rows.ToList();
            _totalRows = total;
            _columns = columns;
        }
        catch (Exception ex)
        {
            _dataError = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            _dataLoading = false;
        }
    }

    private async Task PrevPage()
    {
        if (_page <= 1) return;
        _page--;
        await ReloadData();
    }

    private async Task NextPage()
    {
        if (_page * PageSize >= _totalRows) return;
        _page++;
        await ReloadData();
    }

    private static object? GetPropValue(object obj, string propName)
    {
        try { return obj.GetType().GetProperty(propName)?.GetValue(obj); }
        catch { return null; }
    }

    private static string FormatValue(object? v) => v switch
    {
        null => "—",
        DateTimeOffset dto => dto.LocalDateTime.ToString("g"),
        DateTime dt => dt.ToString("g"),
        bool b => b ? "✓" : "✗",
        _ => v.ToString() ?? "—"
    };
}
