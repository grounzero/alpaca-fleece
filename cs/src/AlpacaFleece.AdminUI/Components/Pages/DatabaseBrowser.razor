@page "/database"
@* @attribute [Authorize] *@
@using Microsoft.EntityFrameworkCore.Metadata
@inject IDbContextFactory<TradingDbContext> DbFactory
@inject EfGridDataService EfGridService
@inject ISnackbar Snackbar

<PageTitle>Database — AlpacaFleece Admin</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">Database</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Browse all database tables with advanced filtering, sorting, and column management.
</MudText>

<MudGrid Spacing="3">
    @* ── Table list panel ── *@
    <MudItem xs="12" md="3">
        <MudPaper Elevation="2" Class="pa-2">
            <MudText Typo="Typo.subtitle2" Class="pa-2">Tables</MudText>
            @if (_tableLoading)
            {
                <MudProgressLinear Indeterminate />
            }
            else
            {
                <MudList T="TableInfo" Dense SelectedValue="_selected" SelectedValueChanged="@SelectTable">
                    @foreach (var t in _tables)
                    {
                        <MudListItem T="TableInfo" Value="t">
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.body2">@t.DisplayName</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                    @t.RowCount
                                </MudChip>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>
    </MudItem>

    @* ── Data panel ── *@
    <MudItem xs="12" md="9">
        @if (_selected is null)
        {
            <MudAlert Severity="Severity.Info">Select a table on the left to browse its data.</MudAlert>
        }
        else
        {
            @switch (_selected.Name)
            {
                case "Trades":
                    <DbTableGrid T="TradeEntity"
                        TableKey="Trades"
                        Title="Trades"
                        Columns="@_tradesCols"
                        ServerData="@LoadTrades"
                        RowDetail="@TradeDetail" />
                    break;

                case "OrderIntents":
                    <DbTableGrid T="OrderIntentEntity"
                        TableKey="OrderIntents"
                        Title="Order Intents"
                        Columns="@_orderIntentsCols"
                        ServerData="@LoadOrderIntents"
                        RowDetail="@OrderIntentDetail" />
                    break;

                case "EquityCurve":
                    <DbTableGrid T="EquityCurveEntity"
                        TableKey="EquityCurve"
                        Title="Equity Curve"
                        Columns="@_equityCurveCols"
                        ServerData="@LoadEquityCurve" />
                    break;

                case "BotState":
                    <DbTableGrid T="BotStateEntity"
                        TableKey="BotState"
                        Title="Bot State"
                        Columns="@_botStateCols"
                        ServerData="@LoadBotState" />
                    break;

                case "Bars":
                    <DbTableGrid T="BarEntity"
                        TableKey="Bars"
                        Title="Bars"
                        Columns="@_barsCols"
                        ServerData="@LoadBars" />
                    break;

                case "PositionSnapshots":
                    <DbTableGrid T="PositionSnapshotEntity"
                        TableKey="PositionSnapshots"
                        Title="Position Snapshots"
                        Columns="@_positionSnapshotsCols"
                        ServerData="@LoadPositionSnapshots" />
                    break;

                case "SignalGates":
                    <DbTableGrid T="SignalGateEntity"
                        TableKey="SignalGates"
                        Title="Signal Gates"
                        Columns="@_signalGatesCols"
                        ServerData="@LoadSignalGates" />
                    break;

                case "Fills":
                    <DbTableGrid T="FillEntity"
                        TableKey="Fills"
                        Title="Fills"
                        Columns="@_fillsCols"
                        ServerData="@LoadFills" />
                    break;

                case "PositionTracking":
                    <DbTableGrid T="PositionTrackingEntity"
                        TableKey="PositionTracking"
                        Title="Position Tracking"
                        Columns="@_positionTrackingCols"
                        ServerData="@LoadPositionTracking" />
                    break;

                case "ExitAttempts":
                    <DbTableGrid T="ExitAttemptEntity"
                        TableKey="ExitAttempts"
                        Title="Exit Attempts"
                        Columns="@_exitAttemptsCols"
                        ServerData="@LoadExitAttempts" />
                    break;

                case "ReconciliationReports":
                    <DbTableGrid T="ReconciliationReportEntity"
                        TableKey="ReconciliationReports"
                        Title="Reconciliation Reports"
                        Columns="@_reconciliationReportsCols"
                        ServerData="@LoadReconciliationReports" />
                    break;

                case "SchemaMeta":
                    <DbTableGrid T="SchemaMetaEntity"
                        TableKey="SchemaMeta"
                        Title="Schema Meta"
                        Columns="@_schemaMetaCols"
                        ServerData="@LoadSchemaMeta" />
                    break;

                case "CircuitBreakerState":
                    <DbTableGrid T="CircuitBreakerStateEntity"
                        TableKey="CircuitBreakerState"
                        Title="Circuit Breaker"
                        Columns="@_circuitBreakerStateCols"
                        ServerData="@LoadCircuitBreakerState" />
                    break;

                case "DrawdownState":
                    <DbTableGrid T="DrawdownStateEntity"
                        TableKey="DrawdownState"
                        Title="Drawdown State"
                        Columns="@_drawdownStateCols"
                        ServerData="@LoadDrawdownState" />
                    break;
            }
        }
    </MudItem>
</MudGrid>

@code {
    private List<TableInfo> _tables = [];
    private TableInfo? _selected;
    private bool _tableLoading = true;
    private IModel? _dbModel;

    // Column definitions for each table (lazily initialized)
    private IReadOnlyList<DbColumnDef<TradeEntity>>? _tradesCols;
    private IReadOnlyList<DbColumnDef<OrderIntentEntity>>? _orderIntentsCols;
    private IReadOnlyList<DbColumnDef<EquityCurveEntity>>? _equityCurveCols;
    private IReadOnlyList<DbColumnDef<BotStateEntity>>? _botStateCols;
    private IReadOnlyList<DbColumnDef<BarEntity>>? _barsCols;
    private IReadOnlyList<DbColumnDef<PositionSnapshotEntity>>? _positionSnapshotsCols;
    private IReadOnlyList<DbColumnDef<SignalGateEntity>>? _signalGatesCols;
    private IReadOnlyList<DbColumnDef<FillEntity>>? _fillsCols;
    private IReadOnlyList<DbColumnDef<PositionTrackingEntity>>? _positionTrackingCols;
    private IReadOnlyList<DbColumnDef<ExitAttemptEntity>>? _exitAttemptsCols;
    private IReadOnlyList<DbColumnDef<ReconciliationReportEntity>>? _reconciliationReportsCols;
    private IReadOnlyList<DbColumnDef<SchemaMetaEntity>>? _schemaMetaCols;
    private IReadOnlyList<DbColumnDef<CircuitBreakerStateEntity>>? _circuitBreakerStateCols;
    private IReadOnlyList<DbColumnDef<DrawdownStateEntity>>? _drawdownStateCols;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _dbModel = db.Model; // Cache model for column generation

            // Load table list
            _tables =
            [
                new("OrderIntents",          "Order Intents",          await db.OrderIntents.CountAsync()),
                new("Trades",                "Trades",                 await db.Trades.CountAsync()),
                new("EquityCurve",           "Equity Curve",           await db.EquityCurve.CountAsync()),
                new("BotState",              "Bot State",              await db.BotState.CountAsync()),
                new("Bars",                  "Bars",                   await db.Bars.CountAsync()),
                new("PositionSnapshots",     "Position Snapshots",     await db.PositionSnapshots.CountAsync()),
                new("SignalGates",           "Signal Gates",           await db.SignalGates.CountAsync()),
                new("Fills",                 "Fills",                  await db.Fills.CountAsync()),
                new("PositionTracking",      "Position Tracking",      await db.PositionTracking.CountAsync()),
                new("ExitAttempts",          "Exit Attempts",          await db.ExitAttempts.CountAsync()),
                new("ReconciliationReports", "Reconciliation Reports", await db.ReconciliationReports.CountAsync()),
                new("SchemaMeta",            "Schema Meta",            await db.SchemaMeta.CountAsync()),
                new("CircuitBreakerState",   "Circuit Breaker",        await db.CircuitBreakerState.CountAsync()),
                new("DrawdownState",         "Drawdown State",         await db.DrawdownState.CountAsync()),
            ];
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load table list: {ex.Message}", Severity.Error);
        }
        finally
        {
            _tableLoading = false;
        }
    }

    private async Task SelectTable(TableInfo? t)
    {
        _selected = t;
        if (t is null)
            return;

        try
        {
            // Lazily initialize columns for this table
            switch (t.Name)
            {
                case "Trades":
                    _tradesCols ??= EfColumnFactory.Generate<TradeEntity>(_dbModel!);
                    break;
                case "OrderIntents":
                    _orderIntentsCols ??= EfColumnFactory.Generate<OrderIntentEntity>(_dbModel!);
                    break;
                case "EquityCurve":
                    _equityCurveCols ??= EfColumnFactory.Generate<EquityCurveEntity>(_dbModel!);
                    break;
                case "BotState":
                    _botStateCols ??= EfColumnFactory.Generate<BotStateEntity>(_dbModel!);
                    break;
                case "Bars":
                    _barsCols ??= EfColumnFactory.Generate<BarEntity>(_dbModel!);
                    break;
                case "PositionSnapshots":
                    _positionSnapshotsCols ??= EfColumnFactory.Generate<PositionSnapshotEntity>(_dbModel!);
                    break;
                case "SignalGates":
                    _signalGatesCols ??= EfColumnFactory.Generate<SignalGateEntity>(_dbModel!);
                    break;
                case "Fills":
                    _fillsCols ??= EfColumnFactory.Generate<FillEntity>(_dbModel!);
                    break;
                case "PositionTracking":
                    _positionTrackingCols ??= EfColumnFactory.Generate<PositionTrackingEntity>(_dbModel!);
                    break;
                case "ExitAttempts":
                    _exitAttemptsCols ??= EfColumnFactory.Generate<ExitAttemptEntity>(_dbModel!);
                    break;
                case "ReconciliationReports":
                    _reconciliationReportsCols ??= EfColumnFactory.Generate<ReconciliationReportEntity>(_dbModel!);
                    break;
                case "SchemaMeta":
                    _schemaMetaCols ??= EfColumnFactory.Generate<SchemaMetaEntity>(_dbModel!);
                    break;
                case "CircuitBreakerState":
                    _circuitBreakerStateCols ??= EfColumnFactory.Generate<CircuitBreakerStateEntity>(_dbModel!);
                    break;
                case "DrawdownState":
                    _drawdownStateCols ??= EfColumnFactory.Generate<DrawdownStateEntity>(_dbModel!);
                    break;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading table {t.DisplayName}: {ex.Message}", Severity.Error);
            _selected = null;
        }

        // Force re-render of the switch statement
        StateHasChanged();
    }

    // ── Server data callbacks (one per table) ──

    private async Task<GridData<TradeEntity>> LoadTrades(GridState<TradeEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.Trades.AsNoTracking(), state,
            searchableProps: ["Symbol", "Side", "ClientOrderId"]);
    }

    private async Task<GridData<OrderIntentEntity>> LoadOrderIntents(GridState<OrderIntentEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.OrderIntents.AsNoTracking(), state,
            searchableProps: ["Symbol", "Side", "ClientOrderId", "Status"]);
    }

    private async Task<GridData<EquityCurveEntity>> LoadEquityCurve(GridState<EquityCurveEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.EquityCurve.AsNoTracking(), state);
    }

    private async Task<GridData<BotStateEntity>> LoadBotState(GridState<BotStateEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.BotState.AsNoTracking(), state,
            searchableProps: ["Key", "Value"]);
    }

    private async Task<GridData<BarEntity>> LoadBars(GridState<BarEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.Bars.AsNoTracking(), state,
            searchableProps: ["Symbol", "Timeframe"]);
    }

    private async Task<GridData<PositionSnapshotEntity>> LoadPositionSnapshots(GridState<PositionSnapshotEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.PositionSnapshots.AsNoTracking(), state,
            searchableProps: ["Symbol"]);
    }

    private async Task<GridData<SignalGateEntity>> LoadSignalGates(GridState<SignalGateEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.SignalGates.AsNoTracking(), state,
            searchableProps: ["GateName"]);
    }

    private async Task<GridData<FillEntity>> LoadFills(GridState<FillEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.Fills.AsNoTracking(), state,
            searchableProps: ["AlpacaOrderId", "ClientOrderId"]);
    }

    private async Task<GridData<PositionTrackingEntity>> LoadPositionTracking(GridState<PositionTrackingEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.PositionTracking.AsNoTracking(), state,
            searchableProps: ["Symbol"]);
    }

    private async Task<GridData<ExitAttemptEntity>> LoadExitAttempts(GridState<ExitAttemptEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.ExitAttempts.AsNoTracking(), state,
            searchableProps: ["Symbol"]);
    }

    private async Task<GridData<ReconciliationReportEntity>> LoadReconciliationReports(GridState<ReconciliationReportEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.ReconciliationReports.AsNoTracking(), state,
            searchableProps: ["Status"]);
    }

    private async Task<GridData<SchemaMetaEntity>> LoadSchemaMeta(GridState<SchemaMetaEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.SchemaMeta.AsNoTracking(), state,
            searchableProps: ["Description"]);
    }

    private async Task<GridData<CircuitBreakerStateEntity>> LoadCircuitBreakerState(GridState<CircuitBreakerStateEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.CircuitBreakerState.AsNoTracking(), state);
    }

    private async Task<GridData<DrawdownStateEntity>> LoadDrawdownState(GridState<DrawdownStateEntity> state)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return await EfGridService.QueryAsync(
            db.DrawdownState.AsNoTracking(), state,
            searchableProps: ["Level"]);
    }

    // ── Row detail fragments ──

    private readonly RenderFragment<TradeEntity> TradeDetail = trade =>
        @<div>
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Alpaca Order ID</MudText>
                    <MudText Typo="Typo.body2">@(trade.AlpacaOrderId ?? "—")</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Client Order ID</MudText>
                    <MudText Typo="Typo.body2" Style="font-family:monospace;font-size:0.85rem">@trade.ClientOrderId</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Initial Quantity</MudText>
                    <MudText Typo="Typo.body2">@trade.InitialQuantity.ToString("G")</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Average Entry Price</MudText>
                    <MudText Typo="Typo.body2">@trade.AverageEntryPrice.ToString("C")</MudText>
                </MudItem>
            </MudGrid>
        </div>;

    private readonly RenderFragment<OrderIntentEntity> OrderIntentDetail = order =>
        @<div>
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Alpaca Order ID</MudText>
                    <MudText Typo="Typo.body2">@(order.AlpacaOrderId ?? "—")</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Client Order ID</MudText>
                    <MudText Typo="Typo.body2" Style="font-family:monospace;font-size:0.85rem">@order.ClientOrderId</MudText>
                </MudItem>
                @if (order.AtrSeed.HasValue)
                {
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">ATR Seed</MudText>
                        <MudText Typo="Typo.body2">@order.AtrSeed.Value.ToString("F4")</MudText>
                    </MudItem>
                }
                @if (order.FilledAt.HasValue)
                {
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Filled At</MudText>
                        <MudText Typo="Typo.body2">@order.FilledAt.Value.LocalDateTime.ToString("g")</MudText>
                    </MudItem>
                }
            </MudGrid>
        </div>;
}
