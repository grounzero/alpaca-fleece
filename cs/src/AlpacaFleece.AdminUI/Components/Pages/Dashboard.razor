@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@implements IAsyncDisposable
@inject AdminDbService DbService
@inject IOptions<AdminOptions> AdminOpts
@inject ISnackbar Snackbar

<PageTitle>Dashboard — AlpacaFleece Admin</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">Dashboard</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Bot status, health flags, and key metrics.
    @if (_vm is not null)
    {
        <span class="ml-2 mud-text-secondary" style="font-size:0.75rem">
            Last updated @_vm.LastUpdated.LocalDateTime.ToString("HH:mm:ss")
        </span>
    }
</MudText>

@if (_loading && _vm is null)
{
    <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-4" />
    <MudGrid>
        @for (var i = 0; i < 8; i++)
        {
            <MudItem xs="12" sm="6" md="3">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="100px" />
            </MudItem>
        }
    </MudGrid>
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else if (_vm is not null)
{
    @* ── Status row ── *@
    <MudGrid Class="mb-4" Spacing="2">
        <MudItem xs="12">
            <MudPaper Class="pa-3 d-flex flex-wrap align-center gap-3" Elevation="1">
                <MudText Typo="Typo.caption" Class="mud-text-secondary mr-1">STATUS</MudText>

                <StatusBadge Status="@(_vm.TradingReady ? "running" : "stopped")"
                             Tooltip="@(_vm.TradingReady ? "Bot is initialised and accepting signals" : "Bot is not ready")" />

                @if (_vm.MarketDataDegraded)
                {
                    <StatusBadge Status="degraded" Tooltip="Market data is degraded — price fetch failures detected" />
                }

                <DrawdownBadge Level="@_vm.DrawdownLevel" />

                @if (_vm.IsPaperTrading)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">PAPER</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">LIVE</MudChip>
                }

                @if (_vm.DryRun)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">DRY RUN</MudChip>
                }

                @if (_vm.KillSwitchActive)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">KILL SWITCH</MudChip>
                }

                <MudSpacer />
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    DB: @(_vm.DatabaseConnected ? "Connected" : "Disconnected")
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Size="Size.Small"
                               OnClick="@RefreshAsync"
                               Disabled="_loading"
                               title="Refresh now" />
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ── Metrics cards ── *@
    <MudGrid Class="mb-4" Spacing="2">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="stat-card pa-4" Elevation="2">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">PORTFOLIO EQUITY</MudText>
                <MudText Typo="Typo.h5">@_vm.EquityValue.ToString("C")</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Cash: @_vm.CashBalance.ToString("C")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="stat-card pa-4" Elevation="2">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">DAILY P&amp;L</MudText>
                <MudText Typo="Typo.h5" Class="@(_vm.DailyPnl >= 0 ? "pnl-positive" : "pnl-negative")">
                    @_vm.DailyPnl.ToString("C")
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="stat-card pa-4" Elevation="2">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">OPEN POSITIONS</MudText>
                <MudText Typo="Typo.h5">@_vm.OpenPositionCount</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="stat-card pa-4" Elevation="2">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">TRADES TODAY</MudText>
                <MudText Typo="Typo.h5">@_vm.DailyTradeCount</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ── Risk row ── *@
    <MudGrid Class="mb-4" Spacing="2">
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="stat-card pa-4" Elevation="2">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">DRAWDOWN</MudText>
                <div class="d-flex align-center gap-2 mt-1">
                    <DrawdownBadge Level="@_vm.DrawdownLevel" />
                    <MudText Typo="Typo.h6">@((_vm.CurrentDrawdownPct * 100m).ToString("F2"))%</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="stat-card pa-4" Elevation="2">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">CIRCUIT BREAKER</MudText>
                <MudText Typo="Typo.h5" Class="@(_vm.CircuitBreakerCount > 0 ? "mud-error-text" : "")">
                    @_vm.CircuitBreakerCount
                </MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">consecutive failures</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="stat-card pa-4" Elevation="2">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">KILL SWITCH</MudText>
                <MudText Typo="Typo.h5" Class="@(_vm.KillSwitchActive ? "mud-error-text" : "pnl-positive")">
                    @(_vm.KillSwitchActive ? "ACTIVE" : "Off")
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ── Charts ── *@
    <MudGrid Spacing="2">
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Equity Curve (30 days)</MudText>
                @if (_equitySeries.Count > 0)
                {
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@_equitySeries"
                              ChartLabels="@_equityLabels"
                              Width="100%"
                              Height="220px"
                              ChartOptions="@_lineOptions" />
                }
                else
                {
                    <MudText Class="mud-text-secondary">No equity data available.</MudText>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Daily P&amp;L (30 days)</MudText>
                @if (_dailyPnlSeries.Count > 0)
                {
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="@_dailyPnlSeries"
                              ChartLabels="@_dailyPnlLabels"
                              Width="100%"
                              Height="220px"
                              ChartOptions="@_barOptions" />
                }
                else
                {
                    <MudText Class="mud-text-secondary">No P&amp;L data available.</MudText>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ── Bars Chart ── *@
    <MudGrid Spacing="2" Class="mt-4">
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="2">
                <div class="d-flex align-center gap-3 mb-3">
                    <MudText Typo="Typo.subtitle2">OHLC Bars</MudText>
                    <MudSelect T="string" @bind-Value="_barsSymbol" Label="Symbol" Variant="Variant.Outlined" Size="Size.Small"
                               Style="width: 120px;" Disabled="_barsSymbols.Count == 0">
                        @foreach (var symbol in _barsSymbols)
                        {
                            <MudSelectItem Value="@symbol">@symbol</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect T="string" @bind-Value="_barsTimeframe" Label="Timeframe" Variant="Variant.Outlined" Size="Size.Small"
                               Style="width: 120px;" Disabled="_barsTimeframes.Count == 0">
                        @foreach (var tf in _barsTimeframes)
                        {
                            <MudSelectItem Value="@tf">@tf</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@LoadBarsChartAsync" Disabled="_loadingBars">
                        Load
                    </MudButton>
                </div>

                @if (_loadingBars)
                {
                    <MudProgressLinear Indeterminate Color="Color.Primary" />
                }
                else if (_barsSeries.Count > 0)
                {
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@_barsSeries"
                              ChartLabels="@_barsLabels"
                              Width="100%"
                              Height="280px"
                              ChartOptions="@_barsChartOptions" />
                }
                else
                {
                    <MudText Class="mud-text-secondary">No bars data available. Select symbol and timeframe, then click Load.</MudText>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private DashboardViewModel? _vm;
    private bool _loading;
    private string? _error;
    private CancellationTokenSource? _timerCts;

    private List<ChartSeries<double>> _equitySeries = [];
    private string[] _equityLabels = [];
    private List<ChartSeries<double>> _dailyPnlSeries = [];
    private string[] _dailyPnlLabels = [];

    private ChartOptions _lineOptions = new()
    {
        ChartPalette = ["#00BFA5"]
    };

    private ChartOptions _barOptions = new()
    {
        ChartPalette = ["#4FC3F7", "#ef5350"]
    };

    // Bars chart state
    private List<ChartSeries<double>> _barsSeries = [];
    private string[] _barsLabels = [];
    private List<string> _barsSymbols = [];
    private List<string> _barsTimeframes = [];
    private string _barsSymbol = "";
    private string _barsTimeframe = "";
    private bool _loadingBars;
    private ChartOptions _barsChartOptions = new()
    {
        ChartPalette = ["#FF9800", "#2196F3", "#4CAF50", "#F44336"]  // Open, High, Low, Close
    };

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();

        // Start background refresh loop (replaces System.Timers.Timer to avoid async void issues)
        var interval = AdminOpts.Value.DashboardRefreshSeconds;
        _timerCts = new CancellationTokenSource();
        _ = RefreshLoopAsync(interval, _timerCts.Token);
    }

    /// <summary>
    /// Background task that refreshes dashboard data at fixed intervals.
    /// </summary>
    private async Task RefreshLoopAsync(int intervalSeconds, CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(intervalSeconds), ct);
                if (ct.IsCancellationRequested) break;

                try
                {
                    await RefreshAsync();
                    await InvokeAsync(StateHasChanged);
                }
                catch (Exception ex)
                {
                    // Log or handle refresh errors without crashing the loop
                    Snackbar.Add($"Dashboard refresh failed: {ex.Message}", Severity.Warning);
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Expected when component disposes
        }
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _vm = await DbService.GetDashboardAsync();
            BuildChartData();

            // Load bars filters on first refresh
            var (symbols, timeframes) = await DbService.GetBarsFiltersAsync();
            _barsSymbols = symbols.ToList();
            _barsTimeframes = timeframes.ToList();
            if (_barsSymbols.Count > 0 && string.IsNullOrEmpty(_barsSymbol))
            {
                _barsSymbol = _barsSymbols[0];
            }
            if (_barsTimeframes.Count > 0 && string.IsNullOrEmpty(_barsTimeframe))
            {
                _barsTimeframe = _barsTimeframes[0];
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load dashboard: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildChartData()
    {
        if (_vm is null) return;

        // Equity curve
        if (_vm.EquityCurve.Count > 0)
        {
            _equitySeries =
            [
                new ChartSeries<double>
                {
                    Name = "Equity",
                    Data = _vm.EquityCurve.Select(p => (double)p.Value).ToArray()
                }
            ];
            _equityLabels = [.. _vm.EquityCurve.Select(p => p.Timestamp.LocalDateTime.ToString("MM/dd"))];
        }

        // Daily P&L
        if (_vm.DailyPnl30.Count > 0)
        {
            _dailyPnlSeries =
            [
                new ChartSeries<double>
                {
                    Name = "P&L",
                    Data = _vm.DailyPnl30.Select(p => (double)p.Pnl).ToArray()
                }
            ];
            _dailyPnlLabels = [.. _vm.DailyPnl30.Select(p => p.Date)];
        }
    }

    private async Task LoadBarsChartAsync()
    {
        if (string.IsNullOrEmpty(_barsSymbol) || string.IsNullOrEmpty(_barsTimeframe))
        {
            Snackbar.Add("Please select symbol and timeframe", Severity.Warning);
            return;
        }

        _loadingBars = true;
        try
        {
            var bars = await DbService.GetRecentBarsAsync(_barsSymbol, _barsTimeframe, 50);
            if (bars.Count == 0)
            {
                _barsSeries = [];
                _barsLabels = [];
                return;
            }

            // Build OHLC series
            var openData = bars.Select(b => (double)b.Open).ToArray();
            var highData = bars.Select(b => (double)b.High).ToArray();
            var lowData = bars.Select(b => (double)b.Low).ToArray();
            var closeData = bars.Select(b => (double)b.Close).ToArray();

            _barsSeries =
            [
                new ChartSeries<double> { Name = "Open", Data = openData },
                new ChartSeries<double> { Name = "High", Data = highData },
                new ChartSeries<double> { Name = "Low", Data = lowData },
                new ChartSeries<double> { Name = "Close", Data = closeData }
            ];

            _barsLabels = bars
                .Select(b => b.Timestamp.ToString("HH:mm"))
                .ToArray();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load bars: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingBars = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _timerCts?.Cancel();
        _timerCts?.Dispose();
        await ValueTask.CompletedTask;
    }
}
