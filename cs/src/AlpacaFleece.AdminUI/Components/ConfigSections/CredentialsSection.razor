@* API credentials. Values only overwrite if non-empty on save. *@

<MudGrid Spacing="3">
    <MudItem xs="12">
        <MudAlert Severity="Severity.Info" Dense="true">
            Leave fields blank to keep the current value unchanged on save.
        </MudAlert>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudTextField @bind-Value="Draft.ApiKey"
                      Label="ALPACA_API_KEY"
                      InputType="@(_showApiKey ? InputType.Text : InputType.Password)"
                      Adornment="Adornment.End"
                      AdornmentIcon="@(_showApiKey ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                      OnAdornmentClick="@(() => _showApiKey = !_showApiKey)"
                      Placeholder="(unchanged)"
                      @bind-Value:after="MarkDirty" />
    </MudItem>
    <MudItem xs="12" md="6">
        <MudTextField @bind-Value="Draft.SecretKey"
                      Label="ALPACA_SECRET_KEY"
                      InputType="@(_showSecret ? InputType.Text : InputType.Password)"
                      Adornment="Adornment.End"
                      AdornmentIcon="@(_showSecret ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                      OnAdornmentClick="@(() => _showSecret = !_showSecret)"
                      Placeholder="(unchanged)"
                      @bind-Value:after="MarkDirty" />
    </MudItem>
</MudGrid>

@code {
    [CascadingParameter] public ConfigDraft Draft { get; set; } = null!;

    private bool _showApiKey;
    private bool _showSecret;

    private void MarkDirty() => Draft.IsDirty = true;
}
